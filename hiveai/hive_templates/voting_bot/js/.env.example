# =============================================================================
# Hive Voting Bot Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# SECURITY WARNING: Never commit your .env file or share your private keys.
# The posting key can ONLY vote/comment — it cannot transfer funds.
# =============================================================================

# --- Hive Node Connection ---
# Public API nodes. The bot automatically fails over through a built-in list,
# but you can set your preferred primary node here.
HIVE_NODE=https://api.hive.blog

# --- Account Credentials ---
# Your Hive username (without the @ symbol)
HIVE_USERNAME=yourusername

# Your POSTING private key (starts with 5...).
# Find it in your Hive wallet under Keys & Permissions.
# ONLY use the POSTING key — never the active or owner key.
HIVE_POSTING_KEY=your_posting_private_key_here

# --- Voting Rules ---
# Vote weight: 10000 = 100%, 5000 = 50%, 100 = 1%
# Negative values are downvotes (flags): -10000 = 100% downvote
VOTE_WEIGHT=5000

# Minimum author reputation to vote on (filters spam/new accounts)
# Reputation is logarithmic: 25=default, 50=established, 70+=whale
MIN_REPUTATION=25

# Comma-separated list of authors to auto-vote (leave empty to skip author filter)
VOTE_AUTHORS=author1,author2,author3

# Comma-separated list of tags to auto-vote (leave empty to skip tag filter)
# The bot votes if ANY configured tag matches ANY tag on the post
VOTE_TAGS=hive,development,programming

# Minutes to wait after a post is published before voting
# Curation rewards are optimized around the 5-minute mark (see bot comments)
VOTE_DELAY_MINUTES=5

# Maximum votes to cast per 24-hour rolling window
# Each full-power vote costs ~2% of your voting mana
MAX_DAILY_VOTES=20

# Minimum Resource Credits percentage before the bot pauses voting
# RC is consumed by every blockchain operation (votes, comments, transfers)
MIN_RC_PERCENT=20
