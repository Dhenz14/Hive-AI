# Flask secret key for signing session cookies.
# Generate a strong random value for production:
#   python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=change-this-to-a-random-secret-in-production

# Port for the Flask development server
PORT=5050

# Hive blockchain API node URL.
# Alternatives: api.deathwing.me, api.openhive.network, anyx.io
HIVE_NODE=https://api.hive.blog
