# =============================================================================
# HAF (Hive Application Framework) Indexer — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# HAF requires a PostgreSQL database that is populated by hived (the Hive node).
# The hived process writes ALL blockchain data into PostgreSQL via the HAF
# extension. Your indexer then reads from these tables to build custom state.
# =============================================================================

# --- HAF PostgreSQL Connection -----------------------------------------------
# These credentials connect to the PostgreSQL instance where hived + HAF
# extension are running. The database "haf_block_log" is the standard name
# used by HAF installations — it contains all blockchain data.
HAF_DB_HOST=localhost
HAF_DB_PORT=5432
HAF_DB_NAME=haf_block_log
HAF_DB_USER=haf_app
HAF_DB_PASSWORD=your_password

# --- Application Settings ----------------------------------------------------
# APP_NAME: Unique name for your HAF application context. HAF tracks processing
# progress per-app, so each indexer must have a distinct name. This name is
# registered in the hive.contexts table.
APP_NAME=my_haf_indexer

# PORT: The HTTP port for the REST API server (server.js).
PORT=3003

# START_BLOCK: The block number to begin indexing from. Block 1 is genesis.
# For production, you may want to start from a recent block to avoid processing
# the entire 80M+ block history. HAF remembers your last processed block, so
# this is only used on first run.
START_BLOCK=1

# BATCH_SIZE: Number of blocks to process in each database transaction.
# Higher = faster throughput but more memory usage. 1000 is a good default.
# For initial sync of millions of blocks, try 5000-10000.
BATCH_SIZE=1000
