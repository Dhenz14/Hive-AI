# ============================================================================
# Hive Social App — Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# SECURITY WARNING: Never commit your .env file or share your private keys.
# The posting key can vote, post, comment, and follow on your behalf.
# It CANNOT transfer funds, but can still damage your reputation if misused.
# ============================================================================

# Hive API node — public nodes rotate; pick one close to you.
# Full list: https://beacon.peakd.com/
# Popular choices:
#   https://api.hive.blog       — Official, global
#   https://api.deathwing.me    — Fast, EU-based
#   https://anyx.io             — Reliable backup
#   https://rpc.ausbit.dev      — Australia
#   https://hive-api.arcange.eu — EU
HIVE_NODE=https://api.hive.blog

# Your Hive username (without the @ symbol)
HIVE_USERNAME=yourusername

# Your POSTING private key (starts with 5...)
# Find it: Hive Keychain > your account > Keys > Show posting key
# Or: https://wallet.hive.blog > Permissions > Show Private Key (posting)
#
# KEY TYPES (never mix these up!):
#   posting key  — social actions (post, vote, comment, follow) — USE THIS ONE
#   active key   — financial (transfer, power up, witness vote) — do NOT put here
#   owner key    — account recovery, change keys — NEVER use in apps
#   memo key     — encrypt/decrypt transfers — not needed here
HIVE_POSTING_KEY=your_posting_private_key_here

# Express server port
PORT=3000
