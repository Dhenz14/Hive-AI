# =============================================================================
# HiveAI Knowledge Refinery — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# ---------------------
# DATABASE (Required)
# ---------------------

# SQLite — recommended for local/desktop (no server needed, just works):
DATABASE_URL=sqlite:///hiveai.db

# PostgreSQL — recommended for production/server deployments:
#   Local:    postgresql://user:password@localhost:5432/hiveai
#   Neon:     postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/hiveai?sslmode=require
#   Supabase: postgresql://postgres:password@db.xxx.supabase.co:5432/postgres
# DATABASE_URL=postgresql://user:password@localhost:5432/hiveai

# ---------------------
# LLM — Choose ONE (or leave as auto)
# ---------------------

# OPTION A: Local LLM with Ollama (recommended — no API keys, no cost, fully private)
# Just install Ollama and pull models. HiveAI auto-detects it.
# LLM_BACKEND=auto

# OPTION B: Cloud LLM with OpenRouter (optional — for access to larger models)
# Get your key at: https://openrouter.ai/keys
# AI_INTEGRATIONS_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# AI_INTEGRATIONS_OPENROUTER_API_KEY=sk-or-v1-your-key-here

# ---------------------
# OPTIONAL — Features
# ---------------------

# Serper.dev API key for real web search URL discovery
# Without this, the system falls back to LLM-generated URLs (still works, just less accurate)
# Get your key at: https://serper.dev
# SERPER_API_KEY=your-serper-key-here

# Brave Search API key for additional URL discovery (free tier: 2000 queries/month)
# Without this, Brave is simply skipped — other sources still work
# Get your key at: https://brave.com/search/api/
# BRAVE_API_KEY=your-brave-api-key-here

# Enable embedding-based semantic chunking (slower but more precise topic boundaries)
# Default: false (uses fast semchunk library instead)
# SEMANTIC_CHUNKING=false

# Hours before cached crawled pages expire and are re-fetched
# Default: 168 (7 days)
# CRAWL_CACHE_TTL_HOURS=168

# Set to 1 for production mode (uses gunicorn instead of Flask dev server)
# PRODUCTION=0

# Number of gunicorn workers (production mode only)
# WEB_WORKERS=2

# ---------------------
# OPTIONAL — Performance Tuning
# ---------------------

# Concurrent web crawl threads (default: min(CPUs, 5))
# CRAWL_WORKERS=5

# Concurrent LLM extraction threads (default: min(CPUs, 4))
# LLM_WORKERS=4

# Database connection pool settings
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=10
# DB_POOL_TIMEOUT=30
# DB_POOL_RECYCLE=1800

# Set to "require" for cloud databases that need SSL (Neon, Supabase, etc.)
# DB_SSL_MODE=require

# Max characters stored per crawled page
# MAX_RAW_CONTENT_SIZE=100000

# Max characters sent to LLM per extraction batch
# MAX_CHUNK_TEXT_FOR_LLM=15000

# ---------------------
# OPTIONAL — Hardware Profile
# ---------------------

# Auto-detected based on your system (low/medium/high/auto)
# "auto" detects your CPU/RAM and picks the best profile
# "low": 1-2 CPU, <6GB RAM — conservative settings
# "medium": 3-5 CPU, 6-12GB RAM — balanced settings
# "high": 6+ CPU, 12GB+ RAM — maximum throughput
# HARDWARE_PROFILE=auto

# ---------------------
# OPTIONAL — Embedding Model
# ---------------------

# Default: BAAI/bge-m3 (good multilingual, 1024 dims)
# Alternative: Qwen/Qwen3-Embedding-0.6B (6x faster, same dims)
# Switching models requires re-embedding stored data (POST /api/reembed)
# EMBEDDING_MODEL=BAAI/bge-m3

# Semantic similarity threshold for duplicate detection (0.0-1.0)
# Lower = more aggressive filtering, higher = more permissive
# SEMANTIC_SIMILARITY_THRESHOLD=0.82

# pgvector HNSW search parameter (higher = more accurate but slower)
# HNSW_EF_SEARCH=100

# ---------------------
# OPTIONAL — Extraction Quality
# ---------------------

# "high" = uses reasoning model for triple extraction (more accurate facts, slower)
# "standard" = uses fast model for extraction (faster, slightly less accurate)
# Default: high (recommended — extraction is where quality matters most)
# EXTRACTION_QUALITY=high

# ---------------------
# OPTIONAL — Ollama Model Configuration
# ---------------------

# Ollama server URL (default: http://localhost:11434)
# OLLAMA_BASE_URL=http://localhost:11434

# Ollama model names — SWEET SPOT recommendations by hardware:
#
#   RAM    | Reasoning Model   | Fast Model    | Quality
#   -------|-------------------|---------------|--------
#   8 GB   | qwen3:4b          | qwen3:1.7b    | Basic
#   16 GB  | qwen3:8b          | qwen3:4b      | Good
#   32 GB  | qwen3:14b         | qwen3:8b      | Sweet spot (default)
#   64 GB+ | qwen3:32b         | qwen3:14b     | Diminishing returns above this
#
# The reasoning model does the heavy lifting: knowledge extraction and book writing.
# The fast model handles lighter tasks: outlines, reviews, summaries.
# Default: qwen3:14b (reasoning) + qwen3:8b (fast)
# OLLAMA_MODEL_REASONING=qwen3:14b
# OLLAMA_MODEL_FAST=qwen3:8b

# ---------------------
# llama-server (LoRA adapter serving)
# ---------------------
# LLAMA_SERVER_BASE_URL=http://localhost:11435
# LLAMA_SERVER_MODELS=hiveai-v1
# LLAMA_SERVER_MODEL=hiveai-v1

# ---------------------
# Docker deployment settings
# ---------------------
# HIVEAI_MODELS_DIR=./models              # Host path to GGUF model directory
# HIVEAI_MODEL_FILE=current_base.gguf     # GGUF filename inside models dir
# LLM_CTX_SIZE=8192                       # Context window size (llama-server + Flask)
# LLAMA_THREADS=12                        # CPU threads for llama-server

# ---------------------
# HuggingFace Token (for model downloads)
# ---------------------
# HF_TOKEN=hf_YOUR_TOKEN_HERE

# ---------------------
# Multi-Source Miner (background training pair generation)
# ---------------------
# MULTI_MINER_ENABLED=false
# GEMINI_API_KEY=YOUR_GEMINI_KEY_HERE
# AI_INTEGRATIONS_OPENROUTER_API_KEY=sk-or-v1-YOUR_KEY_HERE
# GROQ_API_KEY=gsk_YOUR_KEY_HERE
