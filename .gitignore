env/
.venv/
*.egg-info/
dist/
build/
uv.lock

# Environment / Secrets (NEVER commit)
.env
.env.local
.env.production

# SQLite databases (local data — do not commit)
*.db
*.sqlite
*.sqlite3

# Embedding model cache (downloaded on first run)
models/
sentence-transformers/
torch_cache/

# Knowledge graph cache
hiveai/data/

# Node.js (ArcHive deployment scripts only)
node_modules/
package-lock.json

# System files
.DS_Store
Thumbs.db
