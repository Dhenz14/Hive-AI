*.safetensors
*.gguf
*.pt
# Keep training data JSONL and config files
!loras/training_data/
!loras/training_data/**
# ...except large training exports (too big for GitHub, regenerate locally)
loras/training_data/v[0-9].jsonl
loras/training_data/v[0-9]_*.jsonl
# Auto-improve outputs (deprecated system, never commit)
loras/training_data/auto_improve_*.jsonl

# Synthetic traffic data (generated locally, not checked in)
data/
!data/.gitkeep

# Debug test scripts (one-off, not production)
test_*.py
!tests/

# Calibration/validation result artifacts
*_results.json
*_pass_results.json
confirmation_pass_results.json
organic_validation_results.json
real_traffic_results.json

# Topic gate analysis artifacts
scripts/topic_gate_results/
scripts/topic_gate_labeled_queries.json

# Runtime metrics (regenerated by app)
hiveai/rag_metrics.json

# Misc session artifacts
fizzy-gliding-moore.md
embedding_cache.db

# Claude Code local settings
.claude/

# Junk files
nul
Enter
temp_module.py
{ea},

# One-off download/debug scripts (keep only production pipeline scripts)
scripts/dl_*.sh
scripts/dl_*.py
scripts/diag_*.py
scripts/fix_*.sh
scripts/fix_*.py

# Training data category splits (regenerated by prepare_category_data.py)
loras/training_data/categories/

# Replay buffer (regenerated by build_replay_buffer.py)
loras/training_data/replay_buffer.jsonl

# Tokenizer binaries (downloaded with model, not source)
loras/v*/tokenizer.json
loras/v*/tokenizer_config.json
loras/v*/chat_template.jinja

# Compiled caches
unsloth_compiled_cache/

# Large binary assets in scripts
scripts/design_patterns.pdf

# Continual Learning Pipeline — runtime artifacts
replay/*.jsonl
datasets/*.jsonl
# Preserve training logs (valuable history) but ignore server/temp logs
logs/*_server.log
logs/*_checkpoint.txt
loras/*_consolidation/
loras/training_data/_mixed_replay_*.jsonl
loras/training_data/_consolidation_*.jsonl
