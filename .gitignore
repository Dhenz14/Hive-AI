.idea/
*.log
*.tmp
*.bak
*.swp
*~

# Test files
*.test.js
*.test.cjs
*.spec.js
coverage/
.pytest_cache/
htmlcov/

# Desktop app build artifacts
desktop/dist/
desktop/build/
desktop/src-tauri/target/
desktop/node_modules/

# Cursor
.cursorignore

# LoRA binary artifacts (adapters, checkpoints, GGUF — too large for Git)
loras/v*/adapter_model.safetensors
loras/v*/checkpoint-*/
loras/v*/hiveai-*.gguf
loras/v*/gguf/
loras/v*/merged_gguf/
loras/domains/
